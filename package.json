{
  "name": "ecom-agent-platform",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "install:gateway": "npm --prefix apps/gateway install",
    "install:web": "npm --prefix apps/web install",
    "install:all": "npm run install:gateway && npm run install:web",
    "build:web": "npm --prefix apps/web run build",
    "build:openapi": "node apps/gateway/scripts/build-openapi.js",
    "start:gateway": "npm --prefix apps/gateway run start",
    "dev:gateway": "npm --prefix apps/gateway run dev",
    "dev:web": "npm --prefix apps/web run dev",
    "test": "npm --prefix apps/gateway test",
    "ops:start:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\ops\\windows\\start_all.ps1",
    "ops:stop:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\ops\\windows\\stop_all.ps1",
    "ops:refresh:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\ops\\windows\\run_pg_pipeline.ps1",
    "ops:start:saas": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\ops\\windows\\start_saas_core.ps1",
    "ops:stop:saas": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\ops\\windows\\stop_saas_core.ps1",
    "ops:smoke:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\smoke_all_modules.ps1 -OutputPath .\\runtime\\smoke-last.json"
  }
}
