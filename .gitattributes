# Text files use UTF-8 WITHOUT BOM. Editors that auto-insert BOM (notably
# older Windows tooling) must be configured to emit no BOM, otherwise each
# cross-platform checkout will show spurious diffs. PR11 (2026-04-24) did
# a one-time purge of 23 files with stored BOM.

* text=auto
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
*.sql text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.mjs text eol=lf
